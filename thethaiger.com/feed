		<dc:creator><![CDATA[Ryan Turner]]></dc:creator>
		<pubDate>Wed, 08 Jul 2026 07:31:06 +0000</pubDate>
				<category><![CDATA[Central Thailand News]]></category>
		<category><![CDATA[Thailand News]]></category>
		<category><![CDATA[American]]></category>
